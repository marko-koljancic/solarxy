<?xml version='1.0' encoding='windows-1252'?>
<!--
  WiX template for the solarxy-cli MSI.

  Modelled on the root GUI WXS (../../wix/main.wxs) but stripped to what
  a headless CLI needs:
    - ships `solarxy-cli.exe` (no Start Menu shortcut — discoverability
      is `winget search` / PATH, not the Start Menu);
    - adds %ProgramFiles%\solarxy-cli\bin to PATH;
    - drops an install-source marker at
      %ProgramData%\Solarxy-cli\install-source so that
      `solarxy-cli --update` can detect the MSI install channel via
      solarxy_core::install_source::detect() and route to `winget upgrade`
      instead of attempting an axoupdater self-update (which UAC would
      block on a Program Files install).

  GUIDs (UpgradeCode, path-guid) come from
  [package.metadata.wix] in crates/solarxy-cli/Cargo.toml and MUST stay
  stable across versions — they're what Windows uses to detect upgrades
  of prior installs.
-->

<?if $(sys.BUILDARCH) = x64 or $(sys.BUILDARCH) = arm64 ?>
    <?define PlatformProgramFilesFolder = "ProgramFiles64Folder" ?>
<?else ?>
    <?define PlatformProgramFilesFolder = "ProgramFilesFolder" ?>
<?endif ?>

<Wix xmlns='http://schemas.microsoft.com/wix/2006/wi'>

    <Product
        Id='*'
        Name='solarxy-cli'
        UpgradeCode='288588D5-0A49-46D6-8222-DCD7CEEBC39A'
        Manufacturer='Marko Koljancic'
        Language='1033'
        Codepage='1252'
        Version='$(var.Version)'>

        <Package Id='*'
            Keywords='Installer'
            Description='Solarxy command-line companion: analyze / preferences / docs / self-update. Ships alongside the Solarxy GUI viewer as a separate MSI.'
            Manufacturer='Marko Koljancic'
            InstallerVersion='450'
            Languages='1033'
            Compressed='yes'
            InstallScope='perMachine'
            SummaryCodepage='1252'
            />

        <MajorUpgrade
            Schedule='afterInstallInitialize'
            DowngradeErrorMessage='A newer version of [ProductName] is already installed. Setup will now exit.'/>

        <Media Id='1' Cabinet='media1.cab' EmbedCab='yes' DiskPrompt='CD-ROM #1'/>
        <Property Id='DiskPrompt' Value='solarxy-cli Installation'/>

        <Directory Id='TARGETDIR' Name='SourceDir'>
            <Directory Id='$(var.PlatformProgramFilesFolder)' Name='PFiles'>
                <Directory Id='APPLICATIONFOLDER' Name='solarxy-cli'>
                    <Directory Id='Bin' Name='bin'>
                        <Component Id='Path' Guid='CFFD83AC-37C5-4530-BA68-58EC0D2CAA75' KeyPath='yes'>
                            <Environment
                                Id='PATH'
                                Name='PATH'
                                Value='[Bin]'
                                Permanent='no'
                                Part='last'
                                Action='set'
                                System='yes'/>
                        </Component>
                        <Component Id='binary0' Guid='*'>
                            <File
                                Id='exe0'
                                Name='solarxy-cli.exe'
                                DiskId='1'
                                Source='$(var.CargoTargetBinDir)\solarxy-cli.exe'
                                KeyPath='yes'/>
                        </Component>
                    </Directory>
                </Directory>
            </Directory>

            <!--
              install-source marker. Lets `solarxy-cli --update` identify
              that this binary was installed via MSI (vs shell-installer
              / Homebrew / cargo / etc.) and route the user to
              `winget upgrade` instead of running an axoupdater
              self-update (which UAC would block under Program Files).
              Read by solarxy_core::install_source::detect() at runtime.
              The Solarxy-cli subfolder is distinct from the GUI's
              Solarxy subfolder to avoid any cross-MSI file-ownership
              conflict when both GUI and CLI MSIs are installed.
            -->
            <Directory Id='CommonAppDataFolder'>
                <Directory Id='InstallSourceFolder' Name='Solarxy-cli'>
                    <Component Id='InstallSourceMarker' Guid='*'>
                        <CreateFolder/>
                        <File
                            Id='install_source_marker'
                            Name='install-source'
                            DiskId='1'
                            Source='wix\install-source-msi.txt'
                            KeyPath='yes'/>
                    </Component>
                </Directory>
            </Directory>
        </Directory>

        <Feature
            Id='Binaries'
            Title='Application'
            Description='Installs the solarxy-cli binary.'
            Level='1'
            ConfigurableDirectory='APPLICATIONFOLDER'
            AllowAdvertise='no'
            Display='expand'
            Absent='disallow'>

            <ComponentRef Id='binary0'/>
            <ComponentRef Id='InstallSourceMarker'/>

            <Feature
                Id='Environment'
                Title='PATH Environment Variable'
                Description='Add the install location of [ProductName] to the system PATH so it can be called from any shell.'
                Level='1'
                Absent='allow'>
                <ComponentRef Id='Path'/>
            </Feature>
        </Feature>

        <SetProperty Id='ARPINSTALLLOCATION' Value='[APPLICATIONFOLDER]' After='CostFinalize'/>

        <!--
          Shared product icon with the GUI MSI. Path is relative to the
          solarxy-cli crate's Cargo.toml (where cargo-wix resolves
          Source= attributes), so two levels up lands in the repo root.
        -->
        <Icon Id='ProductICO' SourceFile='..\..\res\bundle\solarxy.ico'/>
        <Property Id='ARPPRODUCTICON' Value='ProductICO' />

        <Property Id='ARPHELPLINK' Value='https://github.com/marko-koljancic/solarxy'/>

        <UI>
            <UIRef Id='WixUI_FeatureTree'/>
            <Publish Dialog='WelcomeDlg' Control='Next' Event='NewDialog' Value='CustomizeDlg' Order='99'>1</Publish>
            <Publish Dialog='CustomizeDlg' Control='Back' Event='NewDialog' Value='WelcomeDlg' Order='99'>1</Publish>
        </UI>

    </Product>

</Wix>
